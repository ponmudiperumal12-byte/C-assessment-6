#include <stdio.h>

int main()
{
    int n, i = 2, count = 0;
     printf ("enter the number:");
    scanf("%d", &n);

    while(i < n)
    {
        if(n % i == 0)
        {
            count++;
        }
        i++;
    }

    if(n > 1 && count == 0)
        printf("Prime");
    else
        printf("Not Prime");
}

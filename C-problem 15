#include <stdio.h>
int main()
{
    int a, temp, f, l;
    int power = 1, m, result;
     printf ("enter the number:");
    scanf("%d", &a);

    l = a % 10;

    temp = a;

    while(temp >= 10)
    {
        temp = temp / 10;
        power = power * 10;
    }

    f = temp;

    m= (a % power) / 10;

    result = l* power + m * 10 + f;

    printf("%d", result);
}

#include <stdio.h>

int main()
{
    int n, temp, sum = 0;
    int i = 2, count = 0;
    printf ("enter the number:");
    scanf("%d", &n);
    temp = n;
    while(temp > 0)
    {
        sum = sum + (temp % 10);
        temp = temp / 10;
    }

    while(i < n)
    {
        if(n % i == 0)
        {
            count++;
        }
        i++;
    }

    if(n > 1 && count == 0 && sum == 14)
        printf("Yes");
    else
        printf("No");
}

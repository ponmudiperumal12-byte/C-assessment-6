#include <stdio.h>
int main()
{
    int n, m, i = 2, count = 0;
    printf ("enter the number:");
    scanf("%d", &n);
    m = (n / 10) % 100;
    while(i < m)
    {
        if(m % i == 0)
        {
            count++;
        }
        i++;
    }

    if(m > 1 && count == 0)
        printf("Prime");
    else
        printf("Not Prime");
}
